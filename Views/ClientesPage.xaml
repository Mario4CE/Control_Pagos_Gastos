<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ClientesPagosApp.ViewModels"
             xmlns:models="clr-namespace:ClientesPagosApp.Models"
             x:Class="ClientesPagosApp.Views.ClientesPage"
             x:DataType="vm:ClientesViewModel"
             Title="Clientes">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Frame Padding="12" BorderColor="LightGray" CornerRadius="8">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Nuevo cliente" FontAttributes="Bold" />

                    <Entry Placeholder="Nombre" Text="{Binding NuevoNombre}" />
                    <Entry Placeholder="Teléfono (opcional)" Keyboard="Telephone" Text="{Binding NuevoTelefono}" />
                    <Entry Placeholder="Nota (opcional)" Text="{Binding NuevaNota}" />

                    <Button Text="Guardar cliente" Command="{Binding GuardarClienteCommand}" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="Clientes registrados" FontAttributes="Bold" Margin="0,10,0,0" />

            <CollectionView ItemsSource="{Binding ClientesLista}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Cliente">
                        <Grid Padding="8" ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="{Binding Nombre}" FontAttributes="Bold" />
                                <Label Text="{Binding Telefono}" FontSize="12" TextColor="Gray" />
                            </VerticalStackLayout>

                            <Label Grid.Column="1"
                                   Text="{Binding Activo, StringFormat='Activo: {0}'}"
                                   VerticalOptions="Center"
                                   FontSize="12" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>